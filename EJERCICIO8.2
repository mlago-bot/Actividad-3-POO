        campoNota1 = new JTextField();
        campoNota1.setBounds(110, 20, 150, 25);
        contenedor.add(campoNota1);


        labelNota2 = new JLabel("Nota 2:");
        labelNota2.setBounds(20, 55, 80, 25);
        contenedor.add(labelNota2);


        campoNota2 = new JTextField();
        campoNota2.setBounds(110, 55, 150, 25);
        contenedor.add(campoNota2);


        labelNota3 = new JLabel("Nota 3:");
        labelNota3.setBounds(20, 90, 80, 25);
        contenedor.add(labelNota3);


        campoNota3 = new JTextField();
        campoNota3.setBounds(110, 90, 150, 25);
        contenedor.add(campoNota3);


        labelNota4 = new JLabel("Nota 4:");
        labelNota4.setBounds(20, 125, 80, 25);
        contenedor.add(labelNota4);


        campoNota4 = new JTextField();
        campoNota4.setBounds(110, 125, 150, 25);
        contenedor.add(campoNota4);


        labelNota5 = new JLabel("Nota 5:");
        labelNota5.setBounds(20, 160, 80, 25);
        contenedor.add(labelNota5);


        campoNota5 = new JTextField();
        campoNota5.setBounds(110, 160, 150, 25);
        contenedor.add(campoNota5);


        calcular = new JButton("Calcular");
        calcular.setBounds(100, 205, 110, 30);
        calcular.addActionListener(this);
