 package ejercicio_8_2;


 import javax.swing.*;
 import java.awt.*;
 import java.awt.event.*;


 public class VentanaPrincipal extends JFrame implements  ActionListener {


    private JLabel labelNota1, labelNota2, labelNota3, labelNota4, labelNota5;
    private JTextField campoNota1, campoNota2, campoNota3, campoNota4, campoNota5;
    private JButton calcular, limpiar;
    private JLabel promedio, desviacion, mayor, menor;


    public VentanaPrincipal() {
        setTitle("Notas del Estudiante");
        setSize(420, 410);
        setLocationRelativeTo(null);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setResizable(false);


